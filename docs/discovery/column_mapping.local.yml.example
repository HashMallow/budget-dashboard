# Local overrides for your real workbook (copy to column_mapping.local.yml).
# Gitignored — safe for customer-specific sheet names.
#
# Not required for import: the importer auto-detects the invoice tab by column headers
# (Invoice Number, Vendor Name, etc.) when the tab name differs from the template.
#
# Use this file when you want explicit tab names (e.g. Excel export sheet title parity).

workbook: "your_workbook.xlsx"

sheets:
  invoices:
    actual_sheet_name: "Marketing Spend Input"
  budget:
    budget_line_mapping:
      year: 1405
